DATABASE_URL=sqlite:///./zoiko.db
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# SMTP email (optional — invites/reminders disabled when blank)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@zoikomeet.com
SMTP_FROM_NAME=Zoiko connect
SMTP_USE_TLS=true

# Frontend URL for invite links
FRONTEND_URL=http://localhost:5173

# AI assistant (optional — chatbot disabled when blank)
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-20250514

# Recording retention — recordings older than this are auto-deleted.
# Set RECORDING_RETENTION_DAYS=0 to disable the cleanup loop.
RECORDING_RETENTION_DAYS=30
RECORDING_CLEANUP_INTERVAL_SECONDS=3600
