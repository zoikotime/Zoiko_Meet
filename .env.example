# =============================================================
# Zoiko Meet — docker-compose environment
# Copy this file to `.env` (in the same directory as docker-compose.yml)
# =============================================================

# --- Local Postgres (used when DATABASE_URL is not set) ---
POSTGRES_PASSWORD=zoiko_dev

# --- OR: point to Supabase / any external Postgres ---
# If set, this overrides the local `db` service.
# Find this in Supabase dashboard → Project Settings → Database → Connection string → URI
# Format:
#   postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DBNAME
# Example (Supabase pooler):
# DATABASE_URL=postgresql+psycopg2://postgres.xxxxxxxxxxxx:YOUR_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# --- JWT ---
JWT_SECRET=replace-with-a-long-random-secret

# --- CORS: comma-separated origins allowed to hit the API ---
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# --- Frontend build-time API base URL ---
# In docker-compose the client is built once; this URL is baked into the bundle.
# Use the URL that *browsers* use to reach the server (not the docker network name).
VITE_API_BASE=http://localhost:8000
